file(
    GLOB BACKEND_SOURCES
    backend/*.cpp
)

add_library(
    hplinalg_backend
    STATIC
        ${BACKEND_SOURCES}
)

target_include_directories(
    hplinalg_backend
    PRIVATE
        ${CMAKE_SOURCE_DIR}/src
    PUBLIC
        ${CMAKE_SOURCE_DIR}/include
)

target_link_libraries(
    hplinalg_backend
    PRIVATE
        hplinalg_utils 
        OpenBLAS::OpenBLAS
    PUBLIC
        hplinalg_data 
)

#Linux runtime path for shared libraries
set_target_properties(hplinalg_backend PROPERTIES
    BUILD_RPATH "${OPENBLAS_ROOT}/lib64"
)

# Set the appropriate source files based on the selected BLAS backend
if(HPLINALG_BLAS_BACKEND STREQUAL "OpenBLAS")
    target_sources(hplinalg_backend PRIVATE
        blas_openblas.cpp
        lapack_openblas.cpp
    )
endif(HPLINALG_BLAS_BACKEND STREQUAL "OpenBLAS")
