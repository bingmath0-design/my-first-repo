add_executable(hplinalg_test main.cpp)
target_link_libraries(hplinalg_test PRIVATE direct_method_core)

#Windows + MKL
if(USE_MKL AND WIN32)
    add_custom_command(
        TARGET hplinalg_test POST_BUILD
        COMMAND ${CMAKE_COMMAND} -E copy_if_different
            "${PROJECT_SOURCE_DIR}/external/mkl_import/mkl_rt.dll"
            "$<TARGET_FILE_DIR:hplinalg_test>/mkl_rt.dll"
    )
endif(USE_MKL AND WIN32)

if(WIN32)
    # 1. copy main imported dll (libNCTIETree.dll) to the test executable directory
    add_custom_command(
        TARGET hplinalg_test POST_BUILD
        COMMAND ${CMAKE_COMMAND} -E copy_if_different
            "$<TARGET_FILE:NCTIETree::NCTIETree>"
            "$<TARGET_FILE_DIR:hplinalg_test>"
    )

    # 2. copy all dependent dlls from the same bin directory to the test executable directory
     add_custom_command(
        TARGET hplinalg_test POST_BUILD
        COMMAND ${CMAKE_COMMAND} -E copy_directory
            "${PROJECT_SOURCE_DIR}/external/etree_gcc_win/bin"
            "$<TARGET_FILE_DIR:hplinalg_test>"
    )
endif(WIN32)
