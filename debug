    hplinalg_utils
    STATIC 
        ${UTILS_SOURCES}
)

target_include_directories(
    hplinalg_utils
    PUBLIC 
        ${PROJECT_SOURCE_DIR}/src
        ${PROJECT_SOURCE_DIR}/include
)   


#-------------Data Layer (header-only)-----------------
add_library(
    hplinalg_data
    INTERFACE 
)

target_include_directories(
    hplinalg_data
    INTERFACE
        ${PROJECT_SOURCE_DIR}/src
        ${PROJECT_SOURCE_DIR}/include
)

target_link_directories(
    hplinalg_data
    INTERFACE
        hplinalg_utils
        eigen_headers
)


#-------------Backend-----------------
file(
    GLOB BACKEND_SOURCES
    backend/*.cpp
)

if(NOT BACKEND_SOURCES)
    message(FATAL_ERROR "No backend source files found in ${PROJECT_SOURCE_DIR}/backend")
endif(NOT BACKEND_SOURCES)

add_library(
    hplinalg_backend
    STATIC
        ${BACKEND_SOURCES}
)

target_include_directories(
    hplinalg_backend
    PUBLIC
        ${PROJECT_SOURCE_DIR}/src
        ${PROJECT_SOURCE_DIR}/include
        ${PROJECT_SOURCE_DIR}/external/eigen-5.0.0
)

target_link_libraries(
    hplinalg_backend
    PUBLIC
        hplinalg_data 
        hplinalg_utils 
)

if(USE_MKL)
    target_compile_definitions(
        hplinalg_backend
        PRIVATE
            USE_MKL   
    )

    target_include_directories(
        hplinalg_backend
        PRIVATE
            ${MKL_ROOT}/include
    )
    
    target_link_directories(
        hplinalg_backend
        PRIVATE
            ${PROJECT_SOURCE_DIR}/external/mkl_import
    )
    
    target_link_libraries(
        hplinalg_backend
        PRIVATE
            mkl_rt
    )
endif(USE_MKL)


