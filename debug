cmake_minimum_required(VERSION 3.20)

project(DirectMethodCore LANGUAGES CXX)

set(CMAKE_CXX_STANDARD 17)
set(CMAKE_CXX_STANDARD_REQUIRED ON)

#------------------- Options ------------------
option(USE_MKL "Use Intel MKL backend" ON)

if(NOT DEFINED MKLROOT AND DEFINED ENV{MKLROOT})
    set(MKLROOT $ENV{MKLROOT})
endif(NOT DEFINED MKLROOT AND DEFINED ENV{MKLROOT})


#------------------- Eigen Header-only ------------------
add_library(
    eigen_headers 
    INTERFACE
)

target_include_directories(
    eigen_headers 
    INTERFACE 
        ${PROJECT_SOURCE_DIR}/external/eigen-5.0.0
)

#------------------- NCTIETree (prebuilt, MinGW) ------------------
add_library(
    NCTIETree::NCTIETree 
    SHARED 
    IMPORTED
    GLOBAL
)

set(_ETREE_ROOT "${PROJECT_SOURCE_DIR}/external/etree_gcc_win")

set_target_properties(
    NCTIETree::NCTIETree 
    PROPERTIES 
        INTERFACE_INCLUDE_DIRECTORIES "${_ETREE_ROOT}/include"
        
        IMPORTED_LOCATION "${_ETREE_ROOT}/lib/libNCTIETree.dll"

        IMPORTED_IMPLIB_DEBUG "${_ETREE_ROOT}/lib/libNCTIETree.dll.a"
        IMPORTED_IMPLIB_RELEASE "${_ETREE_ROOT}/lib/libNCTIETree.dll.a"
        IMPORTED_IMPLIB_RELWITHDEBINFO "${_ETREE_ROOT}/lib/libNCTIETree.dll.a"
        IMPORTED_IMPLIB_MINSIZEREL "${_ETREE_ROOT}/lib/libNCTIETree.dll.a"
)

add_subdirectory(src)
add_subdirectory(tests)

